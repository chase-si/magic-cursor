{
  "name": "magic-cursor-effect",
  "version": "1.0.0",
  "author": "chase wu",
  "email": "chase_si@163.com",
  "url": "https://github.com/chase-si/magic-cursor",
  "description": "Mouse cursor hover visual effects for the web",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "demo": "vite --config vite.config.ts",
    "demo:build": "vite build --config vite.config.ts"
  },
  "keywords": [
    "cursor",
    "mouse",
    "hover",
    "effect",
    "animation"
  ],
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "~5.7.2",
    "vite": "^6.0.3"
  }
}
